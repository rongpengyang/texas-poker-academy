{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.smartpokerlab.com"
        }
      ],
      "destination": "https://smartpokerlab.com/$1",
      "permanent": true
    }
  ]
}
